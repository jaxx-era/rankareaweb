{
  "version": 2,
  "builds": [{ "src": "index.js", "use": "@vercel/node" }],
  "routes": [
    { "src": "/auth/(.*)", "dest": "/index.js" },
    { "src": "/business/(.*)", "dest": "/index.js" },
    { "src": "/analytics/(.*)", "dest": "/index.js" },
    { "src": "/payment/(.*)", "dest": "/index.js" }
  ]
}